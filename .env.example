# Firebase (get from console.firebase.google.com)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Supabase (get from supabase.com → project settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Train APIs (get from sites above)
RAILRADAR_API_KEY=          # railradar.in (primary)
RAPIDAPI_KEY=               # rapidapi.com (backup)
INDIAN_RAIL_API_KEY=        # indianrailapi.com (backup 2)

# Animal APIs — NO KEY NEEDED (free open APIs)
# iNaturalist: https://api.inaturalist.org/v1
# GBIF: https://api.gbif.org/v1
